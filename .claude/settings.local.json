{
  "permissions": {
    "allow": [
      "WebFetch(domain:anthropic.skilljar.com)",
      "WebSearch",
      "Bash(ls:*)",
      "Bash(npx tsx:*)",
      "Bash(npx tsc:*)",
      "Bash(wc -l /Users/burakkaanbilgehan/projects/yt-pipeline/.ai/agents/*.md)",
      "Bash(wc -l /Users/burakkaanbilgehan/projects/yt-pipeline/.ai/skills/*/*.md)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Read(//Users/burakkaanbilgehan/projects/yt-pipeline/.ai/agents/**)",
      "Bash(done)",
      "Bash(/usr/local/bin/npm run:*)",
      "Bash(/opt/homebrew/bin/npm run:*)",
      "Read(//usr/local/bin/**)",
      "Read(//Users/burakkaanbilgehan/.nvm/versions/**)",
      "Bash(/usr/local/bin/node /usr/local/bin/npm run sync-ai --prefix /Users/burakkaanbilgehan/projects/yt-pipeline)",
      "Bash(PATH=/usr/local/bin:$PATH npx tsc --noEmit)",
      "Bash(PATH=/usr/local/bin:$PATH npx tsx .ai/sync.ts)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(python3 *)",
      "Bash(xargs sed *)",
      "Bash(bun run *)",
      "Bash(node *)",
      "Bash(npm run *)",
      "Bash(tee /tmp/render-chokepoints.log)",
      "Bash(grep -n \"\\\\$\\\\|prefix\\\\|suffix\\\\|color\\\\|ACCENT\" src/remotion/templates/data-charts/Counter.tsx)",
      "Bash(awk '{print length, $0}')",
      "Bash(awk '{print $1}')",
      "Bash(awk '{print length\\($0\\)}')",
      "WebFetch(domain:x.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q '\\.ai/'; then PATH=/usr/local/bin:$PATH npx tsx .ai/sync.ts; fi",
            "statusMessage": "Syncing .ai/ configs..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q '\\.ai/'; then PATH=/usr/local/bin:$PATH npx tsx .ai/sync.ts; fi",
            "statusMessage": "Syncing .ai/ configs..."
          }
        ]
      }
    ]
  }
}
