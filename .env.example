# yt-pipeline Environment Variables
# Copy this file to .env and fill in your API keys

# ElevenLabs TTS (required for voiceover generation)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# OpenAI (optional - for DALL-E image generation)
OPENAI_API_KEY=

# Google AI / Gemini (default image provider)
GOOGLE_AI_API_KEY=

# Pexels (required for stock image/video collection)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# YouTube Data API (required for upload and analytics)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
