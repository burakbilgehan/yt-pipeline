# yt-pipeline Environment Variables
# Copy this file to .env and fill in your API keys

# Google Cloud TTS (required for voiceover generation — default provider)
# Create at: https://console.cloud.google.com/apis/credentials
# Restrict to: Cloud Text-to-Speech API only
GOOGLE_CLOUD_API_KEY=

# ElevenLabs TTS (legacy/optional — alternative TTS provider)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# OpenAI (optional - for DALL-E image generation)
OPENAI_API_KEY=


# Pexels (required for stock image/video collection)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# YouTube Data API (required for upload and analytics)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Remotion Render Performance (optional)
# Override defaults for the render script (src/scripts/remotion-render.ts)
REMOTION_CONCURRENCY=8
REMOTION_CRF=18
