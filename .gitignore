# yt-pipeline

node_modules/
dist/
.env
.env.*
!.env.example

# -------------------------------------------------------------------
# CONTENT (channel-specific, NOT part of the pipeline framework)
# The pipeline (agents, commands, scripts, templates) is git-tracked.
# All channel content lives in channels/ and is local only.
# Each channel manages its own content independently.
# -------------------------------------------------------------------
channels/

# Legacy path (pre-refactor) — kept for safety
projects/

# Generated render assets in public/ (Remotion staticFile requires public/ location)
# These are symlinked/copied from channels/<name>/videos/<slug>/assets at render time.
# Pattern: public/<channel-slug>/ or public/<video-slug>/
public/*/

# Root-level channel config (template is in templates/channel-config.json)
channel-config.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Figma plugin build output
figma-plugin/code.js

# Test/temp files — debug screenshots, voice tests, render output
test-*.png
test-*.wav
test_voice.mp3
render-log.txt
nul

# A/B test scratch
ab-test/

# Render output (should always go to channels/<ch>/videos/<slug>/production/output/)
out/
